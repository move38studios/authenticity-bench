# Neon Postgres
DATABASE_URL=postgresql://user:password@your-host.neon.tech/neondb?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=           # min 32 chars, generate with: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000

# Resend (for OTP emails)
RESEND_API_KEY=re_xxxxx
FROM_EMAIL=noreply@yourdomain.com

# Seed admin (first admin email, added to whitelist + gets admin role on first sign-in)
SEED_ADMIN_EMAIL=

# Public
NEXT_PUBLIC_APP_URL=http://localhost:3000
